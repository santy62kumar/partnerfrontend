{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@components/*": [
                "./src/components/*"
            ],
            "@pages/*": [
                "./src/pages/*"
            ],
            "@store/*": [
                "./src/store/*"
            ],
            "@api/*": [
                "./src/api/*"
            ],
            "@utils/*": [
                "./src/utils/*"
            ],
            "@hooks/*": [
                "./src/hooks/*"
            ],
            "@assets/*": [
                "./src/assets/*"
            ]
        }
    }
}